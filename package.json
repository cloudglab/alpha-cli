{
  "name": "@cloudglab/alpha-cli",
  "version": "1.0.0",
  "description": "Alpha platform CLI generated from javams-glab-alpha HTTP APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "alpha": "dist/bin/alpha.js",
    "alpha-cli": "dist/bin/alpha.js",
    "alpha-ci": "dist/bin/alpha-ci.js",
    "alpha-deploy": "dist/bin/alpha-deploy.js",
    "alpha-iter": "dist/bin/alpha-iter.js",
    "alpha-rbac": "dist/bin/alpha-rbac.js",
    "alpha-file": "dist/bin/alpha-file.js",
    "alpha-ops": "dist/bin/alpha-ops.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsx scripts/generate-manifest.ts && node scripts/copy-skills.mjs && tsc -p tsconfig.json && node scripts/fix-bin-mode.mjs",
    "dev": "tsx src/bin/alpha.ts",
    "lint": "oxlint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "coverage": "node scripts/coverage.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "release:smoke-query": "node scripts/release-query-smoke.mjs",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "form-data": "^4.0.1",
    "ssh2": "^1.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/ssh2": "^1.15.5",
    "@vitest/coverage-v8": "^4.1.8",
    "lefthook": "^2.1.9",
    "oxlint": "^1.31.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudglab/alpha-cli.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.24.0"
}
