{
  "name": "@cloudglab/alpha-cli",
  "version": "0.1.0",
  "description": "Alpha platform CLI generated from javams-glab-alpha HTTP APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "alpha": "dist/bin/alpha.js",
    "alpha-cli": "dist/bin/alpha.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/bin/alpha.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "form-data": "^4.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "packageManager": "pnpm@10.24.0"
}
